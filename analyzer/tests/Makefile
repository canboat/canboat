PLATFORM?=$(shell uname | tr '[A-Z]' '[a-z]')-$(shell uname -m)
TARGETDIR=../../rel/$(PLATFORM)
ANALYZER=$(TARGETDIR)/analyzer
TEMPDIR=/tmp

.PHONY: test1 test2 test3 test4 test5 test6 test7 test8 test9 test10 test11 test12 test13 test14 test15 test16 test17 test18 test19 test20 test21 test22 test23 test24 tests

all:	tests

test1:
	$(ANALYZER) < recombine-frames.in > $(TEMPDIR)/recombine-frames.out -debug -q -fixtime recombine 2> $(TEMPDIR)/recombine-frames.err
	diff $(TEMPDIR)/recombine-frames.out recombine-frames.out
	diff $(TEMPDIR)/recombine-frames.err recombine-frames.err

test2:	
	$(ANALYZER) < switch-multi-to-one-line.in > $(TEMPDIR)/switch-multi-to-one-line.out -debug -q -fixtime switch-multi-to-one-line 2> $(TEMPDIR)/switch-multi-to-one-line.err
	diff $(TEMPDIR)/switch-multi-to-one-line.out switch-multi-to-one-line.out
	diff $(TEMPDIR)/switch-multi-to-one-line.err switch-multi-to-one-line.err

#
# This tests TEXT stability
#
test3:	
	$(ANALYZER) < pgn-test.in > $(TEMPDIR)/pgn-test.out -debug -q -fixtime pgn-test 2> $(TEMPDIR)/pgn-test.err
	diff $(TEMPDIR)/pgn-test.out pgn-test.out
	diff $(TEMPDIR)/pgn-test.err pgn-test.err

#
# This tests JSON stability
#
test4:	
	$(ANALYZER) < pgn-test.in > $(TEMPDIR)/pgn-test-json.out -json -fixtime pgn-test 2> $(TEMPDIR)/pgn-test-json.err
	python3 ../validate-json.py --line-by-line $(TEMPDIR)/pgn-test-json.out
	diff $(TEMPDIR)/pgn-test-json.out pgn-test-json.out
	diff $(TEMPDIR)/pgn-test-json.err pgn-test-json.err

#
# This tests JSON stability
#
test5:	
	$(ANALYZER) < pgn-test.in > $(TEMPDIR)/pgn-test-json-nv.out -nv -q -json -fixtime pgn-test 2> $(TEMPDIR)/pgn-test-json-nv.err
	python3 ../validate-json.py --line-by-line $(TEMPDIR)/pgn-test-json-nv.out
	diff $(TEMPDIR)/pgn-test-json-nv.out pgn-test-json-nv.out
	diff $(TEMPDIR)/pgn-test-json-nv.err pgn-test-json-nv.err

#
# This tests JSON stability
#
test6:	
	$(ANALYZER) < pgn-test.in > $(TEMPDIR)/pgn-test-json-debug.out -debug -q -json -fixtime pgn-test 2> $(TEMPDIR)/pgn-test-json-debug.err
	python3 ../validate-json.py --line-by-line $(TEMPDIR)/pgn-test-json-debug.out
	diff $(TEMPDIR)/pgn-test-json-debug.out pgn-test-json-debug.out
	diff $(TEMPDIR)/pgn-test-json-debug.err pgn-test-json-debug.err

#
# This tests JSON stability
#
test7:	
	$(ANALYZER) < pgn-test.in > $(TEMPDIR)/pgn-test-json-nv-debug.out -nv -debug -q -json -fixtime pgn-test 2> $(TEMPDIR)/pgn-test-json-nv-debug.err
	python3 ../validate-json.py --line-by-line $(TEMPDIR)/pgn-test-json-nv-debug.out
	diff $(TEMPDIR)/pgn-test-json-nv-debug.out pgn-test-json-nv-debug.out
	diff $(TEMPDIR)/pgn-test-json-nv-debug.err pgn-test-json-nv-debug.err

#
# This tests capability to read Actisense N2K Ascii format
#
test8:	
	TZ=UTC-1 $(ANALYZER) < pgn-test-actisense.in > $(TEMPDIR)/pgn-test-actisense.out -nv -debug -q -json -fixtime pgn-test 2> $(TEMPDIR)/pgn-test-actisense.err
	python3 ../validate-json.py --line-by-line $(TEMPDIR)/pgn-test-actisense.out
	diff $(TEMPDIR)/pgn-test-actisense.out pgn-test-actisense.out
	diff $(TEMPDIR)/pgn-test-actisense.err pgn-test-actisense.err

#
# This tests that analyzer correctly interprets Raymarine PGN 65379 structure.
# It should not return an error when parsing 126208 Group Command/Acknowledge messages to PGN 65379
#
test9:	
	$(ANALYZER) < pgn-65379-test.in > $(TEMPDIR)/pgn-65379-test.out -debug -q -fixtime pgn-test 2> $(TEMPDIR)/pgn-65379-test.err
	diff $(TEMPDIR)/pgn-65379-test.out pgn-65379-test.out
	diff $(TEMPDIR)/pgn-65379-test.err pgn-65379-test.err

#
# This tests that analyzer correctly parses files with both 'coalesced' FAST pgns and 'separate' FAST pgns.
# This is generated by some converters that do not understand that PGN range 0x1FF00-0x1FFFF is always FAST.
#
test10:	
	$(ANALYZER) -format PLAIN_MIX_FAST < mixed-format.in > $(TEMPDIR)/mixed-format.out -debug -d -fixtime pgn-test 2> $(TEMPDIR)/mixed-format.stderr
	grep plain $(TEMPDIR)/mixed-format.stderr > $(TEMPDIR)/mixed-format.err
	diff $(TEMPDIR)/mixed-format.out mixed-format.out
	diff $(TEMPDIR)/mixed-format.err mixed-format.err

#
# This tests that analyzer correctly parses files with nested ISO_NAME fields
#
test11:	
	$(ANALYZER) -json -nv < pgn-126983.in > $(TEMPDIR)/pgn-126983-nv.out -fixtime pgn-test 2> $(TEMPDIR)/pgn-126983-nv.err
	diff $(TEMPDIR)/pgn-126983-nv.out pgn-126983-nv.out
	diff $(TEMPDIR)/pgn-126983-nv.err pgn-126983-nv.err

#
# This tests that analyzer correctly rounds seconds in long/lat in DMS format
#
test12:	
	$(ANALYZER) -q -geo dd  < dms-format.in >  $(TEMPDIR)/dms-format.out -fixtime pgn-test 2>  $(TEMPDIR)/dms-format.err
	$(ANALYZER) -q -geo dm  < dms-format.in >> $(TEMPDIR)/dms-format.out -fixtime pgn-test 2>> $(TEMPDIR)/dms-format.err
	$(ANALYZER) -q -geo dms < dms-format.in >> $(TEMPDIR)/dms-format.out -fixtime pgn-test 2>> $(TEMPDIR)/dms-format.err
	diff $(TEMPDIR)/dms-format.out dms-format.out
	diff $(TEMPDIR)/dms-format.err dms-format.err

#
# This tests that analyzer correctly formats seconds in Actisense N2K format
#
test13:	
	$(ANALYZER) -q < actisense-format.in > $(TEMPDIR)/actisense-format.out -fixtime pgn-test 2>> $(TEMPDIR)/actisense-format.err
	diff $(TEMPDIR)/actisense-format.out actisense-format.out
	diff $(TEMPDIR)/actisense-format.err actisense-format.err

#
# This tests that PGN 60928 ISO Address Claim preserves full-range device instance values
#
test14:
	$(ANALYZER) -json -nv < pgn-60928.in > $(TEMPDIR)/pgn-60928-nv.out -fixtime pgn-test 2> $(TEMPDIR)/pgn-60928-nv.err
	diff $(TEMPDIR)/pgn-60928-nv.out pgn-60928-nv.out
	diff $(TEMPDIR)/pgn-60928-nv.err pgn-60928-nv.err

#
# This tests that short fast-packet first frames don't read uninitialized memory (issue #623)
#
test15:
	$(ANALYZER) < short-frame.in > $(TEMPDIR)/short-frame.out -debug -q -fixtime short-frame 2> $(TEMPDIR)/short-frame.err
	diff $(TEMPDIR)/short-frame.out short-frame.out
	diff $(TEMPDIR)/short-frame.err short-frame.err

#
# This tests that out-of-range PGNs don't read past the end of pgnList[] in the
# searchForPgn() binary search (issue #644). The first PGN (393216) is the
# FuzzingLabs PoC value; valid PGN 126992 at the end is a decoding control.
#
test16:
	$(ANALYZER) < invalid-pgn-test.in > $(TEMPDIR)/invalid-pgn-test.out -debug -q -fixtime pgn-test 2> $(TEMPDIR)/invalid-pgn-test.err
	diff $(TEMPDIR)/invalid-pgn-test.out invalid-pgn-test.out
	diff $(TEMPDIR)/invalid-pgn-test.err invalid-pgn-test.err

#
# This tests that a message that is short by just a trailing reserved/spare
# field still decodes instead of raising a PGN analysis error (issue #663).
#
test17:
	$(ANALYZER) -json -nv < short-reserved.in > $(TEMPDIR)/short-reserved.out -fixtime short-reserved 2> $(TEMPDIR)/short-reserved.err
	python3 ../validate-json.py --line-by-line $(TEMPDIR)/short-reserved.out
	diff $(TEMPDIR)/short-reserved.out short-reserved.out
	diff $(TEMPDIR)/short-reserved.err short-reserved.err

#
# This tests ISO 11783-3 Transport Protocol reassembly: a real 32-packet BAM
# sequence (PGN 60416 TP.CM + PGN 60160 TP.DT) captured off a Navico NAC-3
# broadcasting PGN 129540 (GNSS Sats in View) with a satellite list too large
# even for fast-packet's 223-byte ceiling. Also covers a second session that
# is aborted mid-transfer (no output expected) and a stray TP.DT frame with
# no open session (silently ignored).
#
test18:
	$(ANALYZER) -json -nv < iso-tp-test.in > $(TEMPDIR)/iso-tp-test.out -fixtime iso-tp-test 2> $(TEMPDIR)/iso-tp-test.err
	python3 ../validate-json.py --line-by-line $(TEMPDIR)/iso-tp-test.out
	diff $(TEMPDIR)/iso-tp-test.out iso-tp-test.out
	diff $(TEMPDIR)/iso-tp-test.err iso-tp-test.err

#
# This tests that the message output buffer (print.c's mbuf, backed by the
# shared growable StringBuffer) does not silently truncate a large decoded
# message. A 148-satellite PGN 129540 payload - the largest a 148-satellite
# GNSS Sats in View list reassembled via ISO Transport Protocol can be
# (255 packets * 7 bytes, ISO TP's own ceiling) - renders to ~50KB in
# -nv -debug -json mode, well past the old fixed 8192-byte buffer.
#
test19:
	$(ANALYZER) -nv -debug -q -json < iso-tp-large-payload-test.in > $(TEMPDIR)/iso-tp-large-payload-test.out -fixtime iso-tp-large-payload-test 2> $(TEMPDIR)/iso-tp-large-payload-test.err
	python3 ../validate-json.py --line-by-line $(TEMPDIR)/iso-tp-large-payload-test.out
	diff $(TEMPDIR)/iso-tp-large-payload-test.out iso-tp-large-payload-test.out
	diff $(TEMPDIR)/iso-tp-large-payload-test.err iso-tp-large-payload-test.err

#
# This tests that a STRING_LAU field whose encoding byte is 0xff (an unset field
# padded with 0xff, e.g. the H5000 pilot in PGN 126998) decodes as an empty field
# instead of raising "Unhandled string type 255" and aborting the whole PGN.
#
test20:
	$(ANALYZER) -json -nv < pgn-126998-lau-ff.in > $(TEMPDIR)/pgn-126998-lau-ff.out -fixtime pgn-126998-lau-ff 2> $(TEMPDIR)/pgn-126998-lau-ff.err
	python3 ../validate-json.py --line-by-line $(TEMPDIR)/pgn-126998-lau-ff.out
	diff $(TEMPDIR)/pgn-126998-lau-ff.out pgn-126998-lau-ff.out
	diff $(TEMPDIR)/pgn-126998-lau-ff.err pgn-126998-lau-ff.err

test21:
	$(ANALYZER) -json -nv < pgn-130823-directory.in > $(TEMPDIR)/pgn-130823-directory.out -fixtime pgn-130823-directory 2> $(TEMPDIR)/pgn-130823-directory.err
	python3 ../validate-json.py --line-by-line $(TEMPDIR)/pgn-130823-directory.out
	diff $(TEMPDIR)/pgn-130823-directory.out pgn-130823-directory.out
	diff $(TEMPDIR)/pgn-130823-directory.err pgn-130823-directory.err

test22:
	$(ANALYZER) -json -nv < pgn-126208-request-130817.in > $(TEMPDIR)/pgn-126208-request-130817.out -fixtime pgn-126208-request-130817 2> $(TEMPDIR)/pgn-126208-request-130817.err
	python3 ../validate-json.py --line-by-line $(TEMPDIR)/pgn-126208-request-130817.out
	diff $(TEMPDIR)/pgn-126208-request-130817.out pgn-126208-request-130817.out
	diff $(TEMPDIR)/pgn-126208-request-130817.err pgn-126208-request-130817.err

test23:
	$(ANALYZER) -json -nv < pgn-130823-truncated.in > $(TEMPDIR)/pgn-130823-truncated.out -fixtime pgn-130823-truncated 2> $(TEMPDIR)/pgn-130823-truncated.err
	python3 ../validate-json.py --line-by-line $(TEMPDIR)/pgn-130823-truncated.out
	diff $(TEMPDIR)/pgn-130823-truncated.out pgn-130823-truncated.out
	diff $(TEMPDIR)/pgn-130823-truncated.err pgn-130823-truncated.err

#
# This tests that a message that arrives already reassembled - one FAST format
# line holding the whole payload, as produced by anything that has done the ISO
# Transport Protocol reassembly for us - is accepted when it is longer than a
# fast packet's 223-byte ceiling. The input is the 1779-byte PGN 129540 payload
# of test19 collapsed onto a single line, and the expected output is byte for
# byte what reassembling that test's 255 TP.DT frames produces.
#
test24:
	$(ANALYZER) -json -nv < iso-tp-preassembled-test.in > $(TEMPDIR)/iso-tp-preassembled-test.out -fixtime iso-tp-preassembled-test 2> $(TEMPDIR)/iso-tp-preassembled-test.err
	python3 ../validate-json.py --line-by-line $(TEMPDIR)/iso-tp-preassembled-test.out
	diff $(TEMPDIR)/iso-tp-preassembled-test.out iso-tp-preassembled-test.out
	diff $(TEMPDIR)/iso-tp-preassembled-test.err iso-tp-preassembled-test.err

tests:	test1 test2 test3 test4 test5 test6 test7 test8 test9 test10 test11 test12 test13 test14 test15 test16 test17 test18 test19 test20 test21 test22 test23 test24
