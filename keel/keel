#!/bin/sh
# keel launcher: run the prebuilt binary, building or downloading it first
# when needed. Usage: keel/keel <command> [args...]  (or put keel/ on PATH)
set -e

KEEL_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
BIN="$KEEL_DIR/target/release/keel"

stale() {
    [ ! -x "$BIN" ] && return 0
    [ "$KEEL_DIR/Cargo.toml" -nt "$BIN" ] && return 0
    [ -n "$(find "$KEEL_DIR/src" -newer "$BIN" 2>/dev/null | head -1)" ] && return 0
    return 1
}

if stale; then
    if command -v cargo >/dev/null 2>&1; then
        echo "keel: building (cargo build --release) ..." >&2
        (cd "$KEEL_DIR" && cargo build --release --quiet)
    elif [ -x "$BIN" ]; then
        : # sources newer but no toolchain: run the stale binary rather than fail
        echo "keel: warning: sources changed but cargo is not installed; running stale binary" >&2
    else
        # No toolchain, no binary: fetch a prebuilt release.
        OS=$(uname | tr '[:upper:]' '[:lower:]')
        ARCH=$(uname -m)
        ASSET="keel-$OS-$ARCH"
        REPO="https://github.com/canboat/canboat"
        mkdir -p "$KEEL_DIR/target/release"
        get() { if command -v curl >/dev/null 2>&1; then curl -fsSL "$1"; else wget -qO- "$1"; fi; }
        dl() { if command -v curl >/dev/null 2>&1; then curl -fsSL -o "$BIN" "$1"; else wget -qO "$BIN" "$1"; fi; }

        echo "keel: no cargo toolchain; downloading prebuilt $ASSET ..." >&2
        if ! dl "$REPO/releases/latest/download/$ASSET"; then
            # keel first ships in the 8.0.0 series. While 8.0.0 is a
            # pre-release, GitHub's "latest" points at the 7.x line, which
            # carries no keel asset - so fall back to the newest v8.0.0*
            # release that does. Newest first: the API lists releases in
            # reverse-chronological order.
            echo "keel: not under 'latest'; looking for a v8.0.0 release ..." >&2
            url=$(get "https://api.github.com/repos/canboat/canboat/releases" 2>/dev/null \
                | grep -o "$REPO/releases/download/v8\.0\.0[^\"]*/$ASSET" \
                | head -1)
            if [ -z "$url" ] || ! dl "$url"; then
                echo "keel: could not download $ASSET from 'latest' or any v8.0.0 release." >&2
                echo "keel: install a Rust toolchain and re-run, or build it with" >&2
                echo "keel:   (cd $KEEL_DIR && cargo build --release)" >&2
                exit 1
            fi
        fi
        chmod +x "$BIN"
    fi
fi

exec "$BIN" "$@"
